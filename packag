@asynccontextmanager
async def lifespan(app: FastAPI):
    """应用生命周期管理"""
    logger.info("API服务启动中...")
    # 启动时初始化
    try:
        from packages.api.routes.realtime import start_realtime_push
        start_realtime_push()
    except Exception as e:
        logger.warning(f"实时推送启动失败: {e}")
    
    yield
    
    # 关闭时清理
    logger.info("API服务关闭中...")
    try:
        from packages.api.routes.realtime import stop_realtime_push
        stop_realtime_push()
    except Exception:
        pass


