# 股票分析系统 - 环境配置示例文件
# 复制此文件为 .env 并填入实际的配置值
#
# 生产环境部署注意事项：
# 1. 确保所有 API 密钥使用强随机值
# 2. 将 DEBUG 设为 false
# 3. 配置正确的 CORS_ORIGINS
# 4. 使用 HTTPS 并配置适当的安全头

# ==================== OpenAI API 配置 ====================
# OpenAI API密钥（或中转商API密钥）
OPENAI_API_KEY=<your_openai_api_key>

# API基础URL（使用中转商时修改此项）
OPENAI_BASE_URL=https://api.openai.com/v1

# 向量化模型名称
OPENAI_MODEL=text-embedding-3-small

# 对话模型名称
OPENAI_CHAT_MODEL=gpt-3.5-turbo

# ==================== 安全配置 ====================
# 应用密钥（用于会话加密等，请使用 openssl rand -hex 32 生成）
SECRET_KEY=<your_secret_key>

# 开发模式（生产环境必须设为 false）
DEBUG=false

# 允许的跨域来源（生产环境请修改为实际域名，多个用逗号分隔）
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# API请求限流（每分钟最大请求数）
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# ==================== 数据库配置 ====================
# 向量数据库路径
VECTOR_DB_PATH=./data/stock_vectors.db

# ==================== 向量化模型配置 ====================
# 模型类型: openai 或 local
EMBEDDING_MODEL_TYPE=openai

# 本地模型配置（如果使用local）
LOCAL_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# ==================== 后端服务配置 ====================
# 服务地址
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# ==================== 数据源配置 ====================
# 股票数据源（可选）
# STOCK_DATA_SOURCE=tushare
# TUSHARE_TOKEN=<your_tushare_token>

# ==================== 日志配置 ====================
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# ==================== 缓存配置 ====================
CACHE_ENABLED=true
CACHE_TTL=3600
